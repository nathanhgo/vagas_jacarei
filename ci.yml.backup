name: CI

on:
  pull_request:
    branches: [dev, main]

jobs:
  test:
    name: Lint + Tests
    runs-on: ubuntu-latest

    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_DB: jacarei_vagas_db
          POSTGRES_USER: jacarei_user
          POSTGRES_PASSWORD: test_password
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: "pip"

      - name: Install Python dependencies
        run: |
          cd backend
          pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run Ruff lint
        run: |
          cd backend
          ruff check .

      - name: Run Ruff format check
        run: |
          cd backend
          ruff format --check .

      - name: Run pytest
        env:
          POSTGRES_DB: jacarei_vagas_db
          POSTGRES_USER: jacarei_user
          POSTGRES_PASSWORD: test_password
          POSTGRES_HOST: localhost
          POSTGRES_PORT: 5432
          DJANGO_SECRET_KEY: ci-secret-key-only-used-in-tests
          DJANGO_DEBUG: "True"
          ALLOWED_HOSTS: localhost,127.0.0.1
          CORS_ALLOWED_ORIGINS: http://localhost:3000
        run: |
          cd backend
          pytest --tb=short
