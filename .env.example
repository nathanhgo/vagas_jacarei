# =============================================================================
# Plataforma de Vagas — Jacareí-SP
# .env.example — Copie para .env e preencha com seus valores
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=jacarei_vagas_db
POSTGRES_USER=jacarei_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Django ---
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ADZUNA_APP_ID=your-adzuna-app-id-here
ADZUNA_APP_KEY=your-adzuna-app-key-here